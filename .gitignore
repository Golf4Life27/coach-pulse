# Outer repo wrapper — prevents `git add -A` from staging
# node_modules / build artifacts inside akb-dashboard. The
# akb-dashboard/.gitignore covers these relative to that subtree;
# this file applies the same protection when staging from the
# parent directory.
**/node_modules/
**/.next/
**/.vercel/

# Python build artifacts — Sprint R's scripts/dedupe_export.py
# creates these when imported / smoke-tested. Build-time only;
# never source.
**/__pycache__/
*.py[cod]

# Obsidian — local-only vault metadata when System Facts /
# investigation notes are browsed in Obsidian. Per-user config
# (workspace layout, plugins, hotkeys) is not source of truth and
# should never collide across machines or with CI's checkout.
.obsidian/
**/.obsidian/
