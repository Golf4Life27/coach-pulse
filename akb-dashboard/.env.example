AIRTABLE_PAT=your_personal_access_token
AIRTABLE_BASE_ID=appp8inLAGTg4qpEZ
DASHBOARD_PASSWORD=your_simple_password
ANTHROPIC_API_KEY=your_anthropic_api_key

# Photo sources for the Appraiser rehab vision pipeline (Phase 4B.1).
# Both required for collectPhotos() in lib/photo-sources.ts. When either
# is missing the rehab GET endpoint returns no_photos_available (422)
# and the operator unlocks the INV-005 manual fallback affordance in
# AppraiserRehabPanel. The nightly retry cron re-attempts vision once
# the keys are restored and surfaces drift via Notes marker.
SCRAPER_API_KEY=your_scraperapi_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Crawler intake (RentCast listings source + Firecrawl renovation filter).
RENTCAST_API_KEY=your_rentcast_key
# Comma-separated operator-provided launch ZIPs (NOT autodiscovered).
CRAWLER_TARGET_ZIPS=
# "true" enables live writes to Listings_V1; unset/false = dry-run only.
CRAWLER_INTAKE_LIVE=
# Firecrawl reads the listing portal page (RentCast has no free-text) to
# exclude renovated/turnkey listings. Required for the intake cron's verify
# stage; when unset, every candidate is rejected firecrawl_not_configured.
FIRECRAWL_API_KEY=your_firecrawl_key
# Per-run Firecrawl /v2/search budget (default 1000). Over budget → stall + Spine.
FIRECRAWL_MAX_SCRAPES_PER_RUN=1000
